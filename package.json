{
  "name": "0xmintyn-defi-platform",
  "version": "1.0.0",
  "description": "Comprehensive Solana DeFi Platform with UBI, Governance, Marketplace, and Cross-chain Bridge",
  "private": true,
  "workspaces": [
    "Backend",
    "Frontend",
    "contracts/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd Backend && npm run dev",
    "dev:frontend": "cd Frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend && npm run build:contracts",
    "build:backend": "cd Backend && npm run build",
    "build:frontend": "cd Frontend && npm run build",
    "build:contracts": "npm run build:contracts:all",
    "build:contracts:all": "concurrently \"npm run build:ubi\" \"npm run build:governance\" \"npm run build:marketplace\" \"npm run build:bridge\" \"npm run build:escrow\" \"npm run build:token\"",
    "build:ubi": "cd contracts/mintyn-ubi-distribution/anchor && anchor build",
    "build:governance": "cd contracts/mintyn-governance/anchor && anchor build",
    "build:marketplace": "cd contracts/mintyn-digital-marketplace/anchor && anchor build",
    "build:bridge": "cd contracts/mintyn-cross-chain-bridge/anchor && anchor build",
    "build:escrow": "cd contracts/mintyn-p2p-escrow/anchor && anchor build",
    "build:token": "cd contracts/mintyn-spl-token/anchor && anchor build",
    "test": "npm run test:backend && npm run test:contracts",
    "test:backend": "cd Backend && npm test",
    "test:contracts": "concurrently \"npm run test:ubi\" \"npm run test:governance\" \"npm run test:marketplace\" \"npm run test:bridge\" \"npm run test:escrow\" \"npm run test:token\"",
    "test:ubi": "cd contracts/mintyn-ubi-distribution/anchor && anchor test",
    "test:governance": "cd contracts/mintyn-governance/anchor && anchor test",
    "test:marketplace": "cd contracts/mintyn-digital-marketplace/anchor && anchor test",
    "test:bridge": "cd contracts/mintyn-cross-chain-bridge/anchor && anchor test",
    "test:escrow": "cd contracts/mintyn-p2p-escrow/anchor && anchor test",
    "test:token": "cd contracts/mintyn-spl-token/anchor && anchor test",
    "deploy": "npm run deploy:contracts && npm run build",
    "deploy:contracts": "npm run deploy:contracts:all",
    "deploy:contracts:all": "concurrently \"npm run deploy:ubi\" \"npm run deploy:governance\" \"npm run deploy:marketplace\" \"npm run deploy:bridge\" \"npm run deploy:escrow\" \"npm run deploy:token\"",
    "deploy:ubi": "cd contracts/mintyn-ubi-distribution/anchor && anchor deploy",
    "deploy:governance": "cd contracts/mintyn-governance/anchor && anchor deploy",
    "deploy:marketplace": "cd contracts/mintyn-digital-marketplace/anchor && anchor deploy",
    "deploy:bridge": "cd contracts/mintyn-cross-chain-bridge/anchor && anchor deploy",
    "deploy:escrow": "cd contracts/mintyn-p2p-escrow/anchor && anchor deploy",
    "deploy:token": "cd contracts/mintyn-spl-token/anchor && anchor deploy",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd Backend && npm start",
    "start:frontend": "cd Frontend && npm start",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd Backend && npx eslint . --ext .ts",
    "lint:frontend": "cd Frontend && npm run lint",
    "clean": "npm run clean:backend && npm run clean:frontend && npm run clean:contracts",
    "clean:backend": "cd Backend && rm -rf build node_modules",
    "clean:frontend": "cd Frontend && rm -rf .next node_modules",
    "clean:contracts": "find contracts -name 'target' -type d -exec rm -rf {} + && find contracts -name 'node_modules' -type d -exec rm -rf {} +",
    "setup": "npm install && npm run setup:backend && npm run setup:frontend && npm run setup:contracts",
    "setup:backend": "cd Backend && npm install",
    "setup:frontend": "cd Frontend && npm install",
    "setup:contracts": "npm run setup:contracts:all",
    "setup:contracts:all": "concurrently \"npm run setup:ubi\" \"npm run setup:governance\" \"npm run setup:marketplace\" \"npm run setup:bridge\" \"npm run setup:escrow\" \"npm run setup:token\"",
    "setup:ubi": "cd contracts/mintyn-ubi-distribution && npm install",
    "setup:governance": "cd contracts/mintyn-governance && npm install",
    "setup:marketplace": "cd contracts/mintyn-digital-marketplace && npm install",
    "setup:bridge": "cd contracts/mintyn-cross-chain-bridge && npm install",
    "setup:escrow": "cd contracts/mintyn-p2p-escrow && npm install",
    "setup:token": "cd contracts/mintyn-spl-token && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "solana",
    "defi",
    "ubi",
    "governance",
    "marketplace",
    "cross-chain",
    "bridge",
    "escrow",
    "spl-token",
    "anchor",
    "blockchain",
    "web3"
  ],
  "author": "0xMintyn Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmintyn/defi-platform.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
