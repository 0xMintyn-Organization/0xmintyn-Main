# 0xMintyn DeFi Platform Environment Configuration

#===========================================
# GLOBAL SETTINGS
#===========================================
NODE_ENV=development
PLATFORM_NAME=0xMintyn DeFi Platform
VERSION=1.0.0

#===========================================
# BACKEND CONFIGURATION
#===========================================
# Server Settings
BACKEND_PORT=8000
BACKEND_HOST=localhost
API_BASE_URL=http://localhost:8000

# Database
MONGODB_URL=mongodb://localhost:27017/0xmintyn
MONGODB_DB_NAME=0xmintyn

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Settings
CORS_ORIGIN=http://localhost:3000,https://app.0xmintyn.com
CORS_CREDENTIALS=true

#===========================================
# FRONTEND CONFIGURATION
#===========================================
# Next.js Settings
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL_INTERNAL=http://localhost:3000

# Social Authentication
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
DISCORD_CLIENT_ID=your-discord-oauth-client-id
DISCORD_CLIENT_SECRET=your-discord-oauth-client-secret

#===========================================
# SOLANA BLOCKCHAIN CONFIGURATION
#===========================================
# Network Settings
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your-solana-private-key-for-backend-operations

# Program IDs (Update after deployment)
NEXT_PUBLIC_UBI_PROGRAM_ID=FqzkXZdwYjurnUKetJCAvaUw5WAqbwzU6gZEwydeEfqS
NEXT_PUBLIC_GOVERNANCE_PROGRAM_ID=FqzkXZdwYjurnUKetJCAvaUw5WAqbwzU6gZEwydeEfqS
NEXT_PUBLIC_MARKETPLACE_PROGRAM_ID=FqzkXZdwYjurnUKetJCAvaUw5WAqbwzU6gZEwydeEfqS
NEXT_PUBLIC_BRIDGE_PROGRAM_ID=FqzkXZdwYjurnUKetJCAvaUw5WAqbwzU6gZEwydeEfqS
NEXT_PUBLIC_ESCROW_PROGRAM_ID=FqzkXZdwYjurnUKetJCAvaUw5WAqbwzU6gZEwydeEfqS
NEXT_PUBLIC_TOKEN_PROGRAM_ID=11111111111111111111111111111112

#  Addresses
NEXT_PUBLIC_MINTYN_TOKEN_MINT=your-mintyn-token-mint-address
NEXT_PUBLIC_GOVERNANCE_TOKEN_MINT=your-governance-token-mint-address

# Wallet Configuration
NEXT_PUBLIC_ENABLE_PHANTOM=true
NEXT_PUBLIC_ENABLE_SOLFLARE=true
NEXT_PUBLIC_ENABLE_BACKPACK=true

#===========================================
# THIRD-PARTY SERVICES
#===========================================
# Stripe Payment Processing
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Cloudinary File Storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Email Service (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password
FROM_EMAIL=noreply@0xmintyn.com
FROM_NAME=0xMintyn Platform

# Pinata IPFS (for NFT metadata)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_API_KEY=your-pinata-secret-key
PINATA_JWT=your-pinata-jwt-token

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

#===========================================
# DEVELOPMENT & TESTING
#===========================================
# Debug Settings
DEBUG=true
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true

# Test Configuration
TEST_MONGODB_URL=mongodb://localhost:27017/0xmintyn_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_SOLANA_NETWORK=localnet
TEST_SOLANA_RPC_URL=http://127.0.0.1:8899

# Anchor Testing
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
ANCHOR_WALLET=~/.config/solana/id.json

#===========================================
# PRODUCTION OVERRIDES
#===========================================
# These should be overridden in production
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/0xmintyn?retryWrites=true&w=majority
# REDIS_URL=rediss://username:password@hostname:port
# NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# CORS_ORIGIN=https://app.0xmintyn.com
# API_BASE_URL=https://api.0xmintyn.com

#===========================================
# FEATURE FLAGS
#===========================================
ENABLE_UBI_DISTRIBUTION=true
ENABLE_GOVERNANCE=true
ENABLE_MARKETPLACE=true
ENABLE_CROSS_CHAIN_BRIDGE=true
ENABLE_P2P_ESCROW=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_SOCIAL_FEATURES=true
ENABLE_MOBILE_APP=false

#===========================================
# SECURITY & MONITORING
#===========================================
# API Keys for monitoring services
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key
NEW_RELIC_LICENSE_KEY=your-newrelic-license-key

# Security Headers
ENABLE_HELMET=true
ENABLE_CORS_PREFLIGHT=true
ENABLE_CSRF_PROTECTION=true

# SSL/TLS Configuration (Production)
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem
FORCE_HTTPS=false
