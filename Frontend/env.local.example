# API base (must end with /api/v1/). Protocol must match backend:
# - Backend on HTTPS (USE_HTTPS=true / npm run dev:https) → use https://localhost:8000/api/v1/
# - Backend on HTTP (npm run dev) → use https://localhost:8000/api/v1/
# Wrong protocol causes ERR_INVALID_HTTP_RESPONSE / ERR_EMPTY_RESPONSE.
NEXT_PUBLIC_SERVER_URI=https://localhost:8000/api/v1/

# Where to redirect after logout (marketing site). Local: https://equalmint.com  Production: https://equalmint.com
NEXT_PUBLIC_MARKETING_URL=https://equalmint.com
