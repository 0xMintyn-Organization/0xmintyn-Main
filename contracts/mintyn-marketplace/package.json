{
  "name": "mintyn-marketplace",
  "version": "1.0.0",
  "description": "Mintyn Digital Marketplace - Secure P2P digital product trading platform",
  "main": "deploy.js",
  "scripts": {
    "build": "cd anchor && anchor build",
    "deploy:devnet": "SOLANA_NETWORK=devnet node deploy.js",
    "deploy:mainnet": "SOLANA_NETWORK=mainnet-beta node deploy.js",
    "test": "cd anchor && anchor test",
    "verify": "node verify.js",
    "clean": "cd anchor && anchor clean"
  },
  "keywords": [
    "solana",
    "marketplace",
    "nft",
    "digital-products",
    "escrow",
    "web3"
  ],
  "author": "Mintyn Team",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.87.6"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}








